# Canonical site origin (no trailing slash). Used for metadata, Open Graph, canonical URLs,
# sitemap and robots. Defaults to the production Vercel URL when unset.
NEXT_PUBLIC_SITE_URL=https://universal-promotions.vercel.app

# Where the Tickets button + event "Get tickets" link out to. Defaults to the PRticket.com
# vendor; set to the exact event page once it's live (e.g. https://boletos.prticket.com/events/en/<slug>).
NEXT_PUBLIC_TICKETS_URL=https://www.prticket.com
